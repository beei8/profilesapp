# JWT Secret - Generate a secure 256-bit random string
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-here

# Environment
NODE_ENV=production

# Setup Key - Generate a secure random string for initial admin setup
# Run: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
SETUP_KEY=your-secure-setup-key-here